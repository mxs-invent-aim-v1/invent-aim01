# ═══════════════════════════════════════════════════════════════════════════
#  InvoiceAI — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#  Copy this file and rename it:  cp .env.production.example .env.production
#  Then fill in the values below.
# ═══════════════════════════════════════════════════════════════════════════

# ── Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret key for production!
# Run: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY

# ── Ollama (set automatically by Docker Compose, override if needed) ─────
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=moondream:latest
OLLAMA_TIMEOUT=180

# ── Processing ────────────────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=60
EXTRACTION_CONFIDENCE_THRESHOLD=0.65
MAX_CONCURRENT_JOBS=3
MAX_FILE_SIZE_MB=50
